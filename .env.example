# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ──────────────
# Get these from: https://console.neon.tech
# Connection pooled URL (for Next.js serverless)
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/velluto?sslmode=require&pgbouncer=true"
# Direct URL (for Prisma migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/velluto?sslmode=require"

# ── Site URL ────────────────────────────────
# In production: your Vercel URL e.g. https://velluto.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:4028

# ── NextAuth ────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-secret
# In production: your Vercel URL
NEXTAUTH_URL=http://localhost:4028

# ── Admin Login ─────────────────────────────
ADMIN_EMAIL=admin@velluto.com
ADMIN_PASSWORD=YourStrongPassword!
